<?xml version="1.0"?>
<ruleset name="NinjaTheme">
    <description>WPCS para NinjaTheme</description>

    <!-- Archivos a analizar -->
    <file>src/</file>
    <file>functions.php</file>

    <!-- Excluir carpetas -->
    <exclude-pattern>*/vendor/*</exclude-pattern>
    <exclude-pattern>*/node_modules/*</exclude-pattern>
    <exclude-pattern>*/build/*</exclude-pattern>

    <!-- Estándar base -->
    <rule ref="WordPress">
        <!-- Reglas a desactivar si el proyecto tiene una convención diferente -->
        <exclude name="WordPress.Files.FileName.InvalidClassFileName" />
        <exclude name="WordPress.WP.I18n.MissingTranslatorsComment" />
    </rule>

    <!-- Versión de PHP mínima a verificar -->
    <rule ref="PHPCompatibilityWP" />
    <config name="minimum_supported_wp_version" value="6.4" />
    <config name="testVersion" value="8.1-" />

    <!-- Declarar el texto domain del proyecto -->
    <rule ref="WordPress.WP.I18n">
        <properties>
            <property name="text_domain" type="array">
                <element value="ninjatheme" />
            </property>
        </properties>
    </rule>
</ruleset>
