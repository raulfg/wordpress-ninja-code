{
    "$schema": "https://schemas.wp.org/trunk/block.json",
    "apiVersion": 3,
    "name": "ninjatheme/portfolio-grid",
    "title": "Portfolio Grid",
    "category": "theme",
    "description": "Muestra los proyectos del CPT portfolio en una cuadrícula.",
    "textdomain": "ninjatheme",
    "editorScript": "file:./index.js",
    "editorStyle": "file:./index.css",
    "style": "file:./style-index.css",
    "render": "file:./render.php",
    "attributes": {
        "columns": {
            "type": "number",
            "default": 3
        },
        "category": {
            "type": "string",
            "default": ""
        }
    },
    "supports": {
        "align": [ "wide", "full" ],
        "color": {
            "background": true,
            "text": false
        },
        "spacing": {
            "padding": true,
            "margin": [ "top", "bottom" ]
        }
    }
}
